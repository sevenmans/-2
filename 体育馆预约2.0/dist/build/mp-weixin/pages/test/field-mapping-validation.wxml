<view class="validation-container data-v-c2640ccf"><view class="header data-v-c2640ccf"><text class="title data-v-c2640ccf">🔍 字段映射完整性验证</text><text class="subtitle data-v-c2640ccf">验证拼场、包场、时间段所有字段都与后端数据库完全匹配</text></view><view class="control-panel data-v-c2640ccf"><view class="input-group data-v-c2640ccf"><text class="label data-v-c2640ccf">场馆ID:</text><input type="number" class="input data-v-c2640ccf" value="{{a}}" bindinput="{{b}}"/></view><view class="input-group data-v-c2640ccf"><text class="label data-v-c2640ccf">测试日期:</text><input type="date" class="input data-v-c2640ccf" value="{{c}}" bindinput="{{d}}"/></view><view class="button-group data-v-c2640ccf"><button bindtap="{{e}}" class="btn primary data-v-c2640ccf">🏟️ 验证包场字段</button><button bindtap="{{f}}" class="btn secondary data-v-c2640ccf">🤝 验证拼场字段</button><button bindtap="{{g}}" class="btn success data-v-c2640ccf">⏰ 验证时间段字段</button><button bindtap="{{h}}" class="btn warning data-v-c2640ccf">🔍 全面验证</button><button bindtap="{{i}}" class="btn error data-v-c2640ccf">🗑️ 清除结果</button></view></view><view class="results-section data-v-c2640ccf"><text class="section-title data-v-c2640ccf">验证结果 ({{j}}项)</text><scroll-view class="results-container data-v-c2640ccf" scroll-y><view wx:for="{{k}}" wx:for-item="result" wx:key="n" class="{{['data-v-c2640ccf', 'result-item', result.o]}}"><view class="result-header data-v-c2640ccf"><text class="result-title data-v-c2640ccf">{{result.a}}</text><text class="{{['data-v-c2640ccf', 'result-status', result.c]}}">{{result.b}}</text><text class="result-time data-v-c2640ccf">{{result.d}}</text></view><view class="result-content data-v-c2640ccf"><text class="result-message data-v-c2640ccf">{{result.e}}</text><view wx:if="{{result.f}}" class="mapping-details data-v-c2640ccf"><text class="mapping-title data-v-c2640ccf">字段映射:</text><view wx:for="{{result.g}}" wx:for-item="map" wx:key="d" class="mapping-item data-v-c2640ccf"><text class="mapping-text data-v-c2640ccf">{{map.a}} → {{map.b}}: {{map.c}}</text></view><view wx:if="{{result.h}}" class="additions-section data-v-c2640ccf"><text class="additions-title data-v-c2640ccf">新增字段:</text><view wx:for="{{result.i}}" wx:for-item="add" wx:key="d" class="addition-item data-v-c2640ccf"><text class="addition-text data-v-c2640ccf">{{add.a}}: {{add.b}} ({{add.c}})</text></view></view></view><view wx:if="{{result.j}}" class="errors-section data-v-c2640ccf"><text class="errors-title data-v-c2640ccf">验证错误:</text><view wx:for="{{result.k}}" wx:for-item="error" wx:key="b" class="error-item data-v-c2640ccf"><text class="error-text data-v-c2640ccf">❌ {{error.a}}</text></view></view><view wx:if="{{result.l}}" class="warnings-section data-v-c2640ccf"><text class="warnings-title data-v-c2640ccf">验证警告:</text><view wx:for="{{result.m}}" wx:for-item="warning" wx:key="b" class="warning-item data-v-c2640ccf"><text class="warning-text data-v-c2640ccf">⚠️ {{warning.a}}</text></view></view></view></view></scroll-view></view><view wx:if="{{l}}" class="stats-section data-v-c2640ccf"><text class="section-title data-v-c2640ccf">验证统计</text><view class="stats-grid data-v-c2640ccf"><view class="stat-item success data-v-c2640ccf"><text class="stat-number data-v-c2640ccf">{{m}}</text><text class="stat-label data-v-c2640ccf">通过</text></view><view class="stat-item warning data-v-c2640ccf"><text class="stat-number data-v-c2640ccf">{{n}}</text><text class="stat-label data-v-c2640ccf">警告</text></view><view class="stat-item error data-v-c2640ccf"><text class="stat-number data-v-c2640ccf">{{o}}</text><text class="stat-label data-v-c2640ccf">失败</text></view><view class="stat-item info data-v-c2640ccf"><text class="stat-number data-v-c2640ccf">{{p}}</text><text class="stat-label data-v-c2640ccf">总计</text></view></view></view></view>