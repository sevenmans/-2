<view class="test-container data-v-f7333f21"><view class="header data-v-f7333f21"><text class="title data-v-f7333f21">🔧 时间段修复测试</text><text class="subtitle data-v-f7333f21">测试营业时间生成、前后端同步、状态刷新</text></view><view class="control-panel data-v-f7333f21"><view class="input-group data-v-f7333f21"><text class="label data-v-f7333f21">场馆ID:</text><input type="number" placeholder="输入场馆ID" class="input data-v-f7333f21" value="{{a}}" bindinput="{{b}}"/></view><view class="input-group data-v-f7333f21"><text class="label data-v-f7333f21">测试日期:</text><input type="date" class="input data-v-f7333f21" value="{{c}}" bindinput="{{d}}"/></view><view class="button-group data-v-f7333f21"><button bindtap="{{e}}" class="test-btn primary data-v-f7333f21">🏗️ 测试时间段生成</button><button bindtap="{{f}}" class="test-btn secondary data-v-f7333f21">🔄 测试状态刷新</button><button bindtap="{{g}}" class="test-btn warning data-v-f7333f21">🗑️ 清除缓存</button></view></view><view class="results-section data-v-f7333f21"><text class="section-title data-v-f7333f21">测试结果</text><view wx:for="{{h}}" wx:for-item="result" wx:key="g" class="result-item data-v-f7333f21"><view class="result-header data-v-f7333f21"><text class="result-title data-v-f7333f21">{{result.a}}</text><text class="{{['data-v-f7333f21', 'result-status', result.c]}}">{{result.b}}</text></view><view class="result-details data-v-f7333f21"><text class="detail-text data-v-f7333f21">{{result.d}}</text><view wx:if="{{result.e}}" class="data-section data-v-f7333f21"><text class="data-title data-v-f7333f21">详细数据:</text><text class="data-content data-v-f7333f21">{{result.f}}</text></view></view></view></view><view wx:if="{{i}}" class="timeslots-section data-v-f7333f21"><text class="section-title data-v-f7333f21">当前时间段 ({{j}}个)</text><view class="timeslot-grid data-v-f7333f21"><view wx:for="{{k}}" wx:for-item="slot" wx:key="e" class="{{['data-v-f7333f21', 'timeslot-item', slot.f]}}"><text class="slot-time data-v-f7333f21">{{slot.a}}-{{slot.b}}</text><text class="slot-price data-v-f7333f21">¥{{slot.c}}</text><text class="slot-status data-v-f7333f21">{{slot.d}}</text></view></view></view><view wx:if="{{l}}" class="venue-info data-v-f7333f21"><text class="section-title data-v-f7333f21">场馆信息</text><view class="info-item data-v-f7333f21"><text class="info-label data-v-f7333f21">名称:</text><text class="info-value data-v-f7333f21">{{m}}</text></view><view class="info-item data-v-f7333f21"><text class="info-label data-v-f7333f21">营业时间:</text><text class="info-value data-v-f7333f21">{{n}} - {{o}}</text></view><view class="info-item data-v-f7333f21"><text class="info-label data-v-f7333f21">价格:</text><text class="info-value data-v-f7333f21">¥{{p}}/小时</text></view></view></view>