<view class="container data-v-746e59ef"><view class="header data-v-746e59ef"><text class="title data-v-746e59ef">🔍 API直接测试</text><text class="subtitle data-v-746e59ef">测试时间段API的实际响应数据</text></view><view class="test-section data-v-746e59ef"><view class="input-group data-v-746e59ef"><text class="label data-v-746e59ef">场馆ID:</text><input type="number" placeholder="输入场馆ID" class="input data-v-746e59ef" value="{{a}}" bindinput="{{b}}"/></view><view class="input-group data-v-746e59ef"><text class="label data-v-746e59ef">日期:</text><input type="text" placeholder="YYYY-MM-DD" class="input data-v-746e59ef" value="{{c}}" bindinput="{{d}}"/></view><button bindtap="{{f}}" class="test-btn data-v-746e59ef" disabled="{{g}}">{{e}}</button></view><view wx:if="{{h}}" class="results-section data-v-746e59ef"><view class="section-title data-v-746e59ef">📋 API原始响应</view><view class="code-block data-v-746e59ef">{{i}}</view></view><view wx:if="{{j}}" class="results-section data-v-746e59ef"><view class="section-title data-v-746e59ef">📊 处理后的时间段数据</view><view class="timeslot-list data-v-746e59ef"><view wx:for="{{k}}" wx:for-item="slot" wx:key="f" class="timeslot-item data-v-746e59ef"><view class="time-range data-v-746e59ef">{{slot.a}} - {{slot.b}}</view><view class="{{['status', 'data-v-746e59ef', slot.d]}}">{{slot.c}}</view><view class="price data-v-746e59ef">¥{{slot.e}}</view></view></view></view><view wx:if="{{l}}" class="results-section data-v-746e59ef"><view class="section-title data-v-746e59ef">📈 状态统计</view><view class="stats-grid data-v-746e59ef"><view class="stat-item data-v-746e59ef"><text class="stat-label data-v-746e59ef">总数</text><text class="stat-value data-v-746e59ef">{{m}}</text></view><view class="stat-item data-v-746e59ef"><text class="stat-label data-v-746e59ef">可预约</text><text class="stat-value available data-v-746e59ef">{{n}}</text></view><view class="stat-item data-v-746e59ef"><text class="stat-label data-v-746e59ef">已预约</text><text class="stat-value reserved data-v-746e59ef">{{o}}</text></view><view class="stat-item data-v-746e59ef"><text class="stat-label data-v-746e59ef">已占用</text><text class="stat-value occupied data-v-746e59ef">{{p}}</text></view><view class="stat-item data-v-746e59ef"><text class="stat-label data-v-746e59ef">维护中</text><text class="stat-value maintenance data-v-746e59ef">{{q}}</text></view></view></view><view wx:if="{{r}}" class="results-section data-v-746e59ef"><view class="section-title data-v-746e59ef">❌ 错误信息</view><view class="error-message data-v-746e59ef">{{s}}</view></view></view>