
.skeleton-container.data-v-2d3e614a {
  padding: 20rpx;
}
.skeleton-item.data-v-2d3e614a {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  -webkit-animation: skeleton-loading-2d3e614a 1.5s infinite;
          animation: skeleton-loading-2d3e614a 1.5s infinite;
  border-radius: 8rpx;
}
@-webkit-keyframes skeleton-loading-2d3e614a {
0% {
    background-position: 200% 0;
}
100% {
    background-position: -200% 0;
}
}
@keyframes skeleton-loading-2d3e614a {
0% {
    background-position: 200% 0;
}
100% {
    background-position: -200% 0;
}
}

