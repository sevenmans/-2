<view class="debug-container data-v-8a027c19"><view class="header data-v-8a027c19"><text class="title data-v-8a027c19">时间段API调试</text><button class="refresh-btn data-v-8a027c19" bindtap="{{a}}">刷新数据</button></view><view class="section data-v-8a027c19"><text class="section-title data-v-8a027c19">测试参数</text><view class="param-item data-v-8a027c19"><text class="param-label data-v-8a027c19">场馆ID:</text><input class="param-input data-v-8a027c19" placeholder="请输入场馆ID" value="{{b}}" bindinput="{{c}}"/></view><view class="param-item data-v-8a027c19"><text class="param-label data-v-8a027c19">日期:</text><input class="param-input data-v-8a027c19" placeholder="YYYY-MM-DD" value="{{d}}" bindinput="{{e}}"/></view><button class="test-btn data-v-8a027c19" bindtap="{{f}}">测试API</button></view><view wx:if="{{g}}" class="section data-v-8a027c19"><text class="section-title data-v-8a027c19">加载中...</text></view><view wx:if="{{h}}" class="section data-v-8a027c19"><text class="section-title data-v-8a027c19">API响应数据</text><view class="response-info data-v-8a027c19"><text class="info-item data-v-8a027c19">响应时间: {{i}}ms</text><text class="info-item data-v-8a027c19">数据条数: {{j}}</text></view><view class="response-data data-v-8a027c19"><text class="data-title data-v-8a027c19">原始响应:</text><text class="data-content data-v-8a027c19">{{k}}</text></view></view><view wx:if="{{l}}" class="section data-v-8a027c19"><text class="section-title data-v-8a027c19">处理后的时间段数据</text><view class="timeslot-list data-v-8a027c19"><view wx:for="{{m}}" wx:for-item="slot" wx:key="g" class="{{['timeslot-item', 'data-v-8a027c19', slot.f]}}"><view class="slot-info data-v-8a027c19"><text class="slot-time data-v-8a027c19">{{slot.a}} - {{slot.b}}</text><text class="slot-status data-v-8a027c19">状态: {{slot.c}}</text><text class="slot-price data-v-8a027c19">价格: ¥{{slot.d}}</text><text class="slot-id data-v-8a027c19">ID: {{slot.e}}</text></view></view></view></view><view wx:if="{{n}}" class="section data-v-8a027c19"><text class="s