<view class="container data-v-bb53d9bf"><view class="header data-v-bb53d9bf"><view class="title-row data-v-bb53d9bf"><text class="title data-v-bb53d9bf">参与者</text><text wx:if="{{a}}" class="sub data-v-bb53d9bf">{{b}} {{c}}-{{d}}</text></view><view wx:if="{{e}}" class="meta data-v-bb53d9bf"><text class="meta-text data-v-bb53d9bf">发起方：{{f}}</text><text class="meta-text data-v-bb53d9bf">人数：{{g}}/{{h}}</text></view></view><view wx:if="{{i}}" class="state data-v-bb53d9bf"><text class="data-v-bb53d9bf">加载中...</text></view><view wx:elif="{{j}}" class="state data-v-bb53d9bf"><text class="error data-v-bb53d9bf">{{k}}</text><button class="btn data-v-bb53d9bf" bindtap="{{l}}">重试</button></view><view wx:else class="content data-v-bb53d9bf"><view wx:if="{{m}}" class="state data-v-bb53d9bf"><text class="data-v-bb53d9bf">暂无参与者信息</text><text class="hint data-v-bb53d9bf">仅发起方可查看完整参与者列表</text></view><view wx:else class="list data-v-bb53d9bf"><view wx:for="{{n}}" wx:for-item="p" wx:key="f" class="item data-v-bb53d9bf"><view class="row data-v-bb53d9bf"><text class="name data-v-bb53d9bf">{{p.a}}</text><text class="{{['badge', 'data-v-bb53d9bf', p.c]}}">{{p.b}}</text></view><view class="row subrow data-v-bb53d9bf"><text class="subtext data-v-bb53d9bf">人数：{{p.d}}</text><text class="subtext data-v-bb53d9bf">联系方式：{{p.e}}</text></view></view></view></view></view>